# Referencia:
# https://git-scm.com/docs/gitignore

# ------------------------------
# Dependencias
# ------------------------------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ------------------------------
# Build / ejecución
# ------------------------------
/.next/
/out/
/build/
/dist/

# ------------------------------
# Cobertura y reportes
# ------------------------------
/coverage
*.lcov
.nyc_output/

# ------------------------------
# Logs y depuración
# ------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*
*.log

# ------------------------------
# Variables de entorno
# ------------------------------
.env*
!.env.example
!.env*.example

# ------------------------------
# Vercel
# ------------------------------
.vercel

# ------------------------------
# TypeScript
# ------------------------------
*.tsbuildinfo
next-env.d.ts

# ------------------------------
# Sistema / editores
# ------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# ------------------------------
# Archivos sensibles
# ------------------------------
*.pem
*.key
*.crt
*.p12
*.cer

# ------------------------------
# Firebase / emuladores / exports locales
# ------------------------------
.firebase/
firestore-debug.log
ui-debug.log
*-debug.log
firebase-debug.log*
firebase-export-*

# ------------------------------
# Caché
# ------------------------------
.cache/
.parcel-cache/
.turbo/
tmp/
temp/

# ------------------------------
# Herramientas de IA / asistentes / contexto local
# Se ignoran datos locales, sesiones, cachés y configuraciones
# privadas de herramientas de IA.
# ------------------------------
.claude/
.cursor/
.cursor-tutor/
.windsurf/
.copilot/
.github/
.agent/
.agents/
.qwen/
.sixth/
.qodo/
.llm/
.ai/
.prompts/
.memory/
.memories/
.sessions/
.context/
.contexts/

# ------------------------------
# Otros
# ------------------------------
*.pid
*.seed
createAdmin.js
resetDatabase.js
CLAUDE.md
AGENT.md
documentacion.txt